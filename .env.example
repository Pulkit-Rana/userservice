# Copy to .env and adjust. Gradle bootRun loads .env automatically (see build.gradle).

# Local dev: use the default Spring profile (application-local.properties — relaxed MySQL/Redis, non-Secure cookies).
# For production builds, set: SPRING_PROFILES_ACTIVE=prod
# SPRING_PROFILES_ACTIVE=local

# Required: Base64-encoded secret, >= 32 bytes after decode (HS256). Example decodes to 32-byte test key — replace in any shared environment.
JWT_SECRET=MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTIzNDU2Nzg5MDE=

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=sync_nest
MYSQL_USER=root
MYSQL_PASSWORD=

APP_INIT_ADMIN_PASSWORD=change-me
APP_INIT_USER_PASSWORD=change-me

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# MUST match an "Authorized redirect URI" in Google Cloud (same scheme/host/port/path).
# Default in application.properties is http://localhost:8080/api/v1/login/oauth2/code/google
# If you open the app via 127.0.0.1, set this to http://127.0.0.1:8080/api/v1/login/oauth2/code/google and add that URI in Google too.
GOOGLE_OAUTH2_REDIRECT_URI=http://localhost:8080/api/v1/login/oauth2/code/google

# Browser Google OAuth2 redirect flow — add redirect URI in Google Cloud Console:
#   http://localhost:8080/api/v1/login/oauth2/code/google
# Then open: http://localhost:8080/api/v1/oauth2/authorization/google
# Use the same origin/port as your SPA (Vite default is 5173).
APP_OAUTH2_SUCCESS_URL=http://localhost:5173/auth/google/callback
APP_OAUTH2_ERROR_URL=http://localhost:5173/auth/google/error

# Outbound mail (Gmail: use an App Password, not your account password).
# Set in .env locally; in cloud use a secret manager and map to these env vars.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# Optional: set MAIL_DEBUG=true only when troubleshooting SMTP locally (noisy; never in prod).
# MAIL_DEBUG=false
